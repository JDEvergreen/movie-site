# Copy to .env and fill in. Never commit .env.
# --- datastores ---
DATABASE_URL=postgresql+psycopg://app:app@localhost:5432/movies
REDIS_URL=redis://localhost:6379/0

# --- TMDB (server-side only; never exposed to the web client) ---
TMDB_API_KEY=
TMDB_READ_TOKEN=

# --- app wiring ---
APP_BASE_URL=http://localhost:3000
API_BASE_URL=http://localhost:8000
MAGIC_LINK_SIGNING_KEY=dev-only-change-me
EMAIL_PROVIDER_KEY=

# --- behavior / tuning ---
DEFAULT_REGION=US
CORPUS_VOTE_COUNT_FLOOR=200
MODEL_VERSION=2026.06.0

# --- web (Next) ---
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
